Options -Indexes

<IfModule mod_headers.c>
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/css "access plus 30 days"
ExpiresByType application/javascript "access plus 30 days"
ExpiresByType text/javascript "access plus 30 days"
ExpiresByType image/jpeg "access plus 180 days"
ExpiresByType image/png "access plus 180 days"
ExpiresByType image/gif "access plus 180 days"
ExpiresByType image/svg+xml "access plus 180 days"
ExpiresByType image/webp "access plus 180 days"
ExpiresByType image/avif "access plus 180 days"
ExpiresByType video/mp4 "access plus 30 days"
ExpiresByType application/pdf "access plus 30 days"
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On

# Force HTTPS.
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonical host: non-www.
RewriteCond %{HTTP_HOST} ^www\.familyvest\.com$ [NC]
RewriteRule ^ https://familyvest.com%{REQUEST_URI} [L,R=301]
</IfModule>

# Legacy URL migration redirects.
Redirect 301 /client-login https://familyvest.com/login
Redirect 301 /complimentary-assessment https://familyvest.com/get-started
Redirect 301 /free-assessment https://familyvest.com/get-started
Redirect 301 /meeting https://familyvest.com/get-started
Redirect 301 /special-needs-planning https://familyvest.com/planning-special-needs
Redirect 301 /planning/retirement https://familyvest.com/planning-retirement
Redirect 301 /planning/special-needs https://familyvest.com/planning-special-needs
Redirect 301 /planning/business-exits https://familyvest.com/planning-business-exits
Redirect 301 /autism-resources https://familyvest.com/autism-resource-navigator
Redirect 301 /blog/legal-considerations-of-special-needs-planning/ https://familyvest.com/blog
Redirect 301 /blog/how-to-start-saving-for-college-and-alternatives-to-529-plans/ https://familyvest.com/blog
Redirect 301 /blog/family-vest/how-to-choose-a-financial-planner-your-ultimate-guide/ https://familyvest.com/blog
Redirect 301 /free-assessment/ https://familyvest.com/get-started
RedirectMatch 301 ^/blog/page/[0-9]+/?$ https://familyvest.com/blog
RedirectMatch 301 ^/family-vest/blog/?$ https://familyvest.com/blog
RedirectMatch 301 ^/family-vest/blog/.+$ https://familyvest.com/blog

<IfModule mod_rewrite.c>
RewriteEngine On

# Serve extensionless HTML routes (e.g., /about -> /about.html).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.(?:php|xml|txt|css|js|png|jpe?g|gif|svg|webp|avif|ico|mp4|pdf)$ [NC]
RewriteRule ^([^/]+)/?$ $1.html [L]
</IfModule>

ErrorDocument 404 /404.html
